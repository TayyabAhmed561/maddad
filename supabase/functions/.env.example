# ============================================================
# Supabase Edge Function secrets
# ============================================================
# These are set in Supabase Dashboard → Edge Functions → Manage secrets.
# They are NEVER bundled into the client build.
# ============================================================

# ── Stripe ───────────────────────────────────────────────────
# Stripe Dashboard → Developers → API Keys → Secret key
# Starts with sk_test_ (test) or sk_live_ (production)
STRIPE_SECRET_KEY=sk_test_your-secret-key-here

# Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
# Starts with whsec_
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# ── Resend ───────────────────────────────────────────────────
# Resend Dashboard → API Keys → your key
# Used by: send-receipt, send-verification-email
RESEND_API_KEY=re_your-api-key-here

# ── Supabase (auto-provided by runtime — do not set manually) ─
# These are injected automatically by the Supabase edge runtime.
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# SUPABASE_ANON_KEY=your-anon-key-here
