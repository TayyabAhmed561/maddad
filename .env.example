# ============================================================
# Maddad Platform — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in real values.
# .env.local is in .gitignore and must NEVER be committed.
#
# All VITE_ variables are bundled into the client-side build.
# Never put secret keys (Stripe secret, Resend, etc.) in
# VITE_ variables — those go in Supabase Edge Function secrets.
# ============================================================


# ── Supabase ────────────────────────────────────────────────
# Project Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Project Settings → API → Project API Keys → anon (public)
# Safe to expose in the browser. RLS policies enforce access.
VITE_SUPABASE_ANON_KEY=your-anon-key-here


# ── Stripe (client-side) ────────────────────────────────────
# Stripe Dashboard → Developers → API Keys → Publishable key
# Starts with pk_test_ (test) or pk_live_ (production)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here


# ── Mapbox ──────────────────────────────────────────────────
# Already configured — do not change the key name.
# Mapbox Account → Tokens → your token
# This key is already in use by the existing map explorer.
VITE_MAPBOX_TOKEN=your-existing-mapbox-token-here


# ── PostHog analytics ───────────────────────────────────────
# PostHog Project Settings → Project API Key
# Privacy-friendly analytics. No PII in event properties.
VITE_POSTHOG_KEY=phc_your-posthog-key-here


# ============================================================
# Edge Function secrets (set in Supabase Dashboard, not here)
# ============================================================
# These are server-side only and must NEVER appear in
# client-side code or VITE_ variables.
#
# Supabase Dashboard → Edge Functions → Manage secrets:
#
# STRIPE_SECRET_KEY
#   Stripe Dashboard → Developers → API Keys → Secret key
#   Starts with sk_test_ (test) or sk_live_ (production)
#
# STRIPE_WEBHOOK_SECRET
#   Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
#   Starts with whsec_
#   Step 10 reminder: ensure guest donations (donor_id IS NULL)
#   collect full_name + address before receipt generation.
#
# RESEND_API_KEY
#   Resend Dashboard → API Keys → your key
#   Used for: donation confirmations, receipts, campaign update
#   notifications, and verification status change emails.
